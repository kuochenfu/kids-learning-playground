# Backend environment variables
# Copy this file to .env and fill in the values

PORT=8080
DB_DSN=postgres://user:password@localhost:5432/kids_playground?sslmode=disable
JWT_SECRET=change-me-to-a-random-256-bit-secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Comma-separated list of admin email(s) for puzzle upload/delete
ADMIN_EMAIL=kuochenfu@gmail.com

# Comma-separated list of parent email(s) (get parent role on first login)
PARENT_EMAILS=frankuo@gmail.com

# Set to true in production (enables Secure + SameSite=None cookie flags)
COOKIE_SECURE=false

# Comma-separated allowed CORS origins. Defaults to localhost:5173 + production URL.
# ALLOWED_ORIGINS=http://localhost:5173,https://kids-learning-playground.pages.dev
